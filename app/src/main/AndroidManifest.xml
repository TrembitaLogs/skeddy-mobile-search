<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Foreground Service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Location permissions for device GPS coordinates in ping -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notification permission (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Battery optimization exemption request -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Boot completed receiver permission -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Internet permission for server communication (ping, login, ride reporting) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Query Lyft Driver app for auto-recovery (Android 11+) -->
    <queries>
        <package android:name="com.lyft.android.driver" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Skeddy"
        tools:targetApi="34">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Skeddy">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.LoginActivity"
            android:exported="false"
            android:label="@string/login_title" />

        <activity
            android:name=".ui.SetupRequiredActivity"
            android:exported="false"
            android:label="@string/setup_required_title" />

        <activity
            android:name=".ui.ForceUpdateActivity"
            android:exported="false"
            android:label="@string/force_update_title" />

        <!-- Accessibility Service for monitoring Lyft app -->
        <service
            android:name=".accessibility.SkeddyAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Foreground Service for persistent monitoring (legacy, to be removed) -->
        <service
            android:name=".service.SkeddyForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="accessibility_monitoring" />
        </service>

        <!-- Monitoring Foreground Service for cyclic ride monitoring -->
        <service
            android:name=".service.MonitoringForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse|location">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="accessibility_monitoring" />
        </service>

        <!-- JobService for restarting monitoring service after kill -->
        <service
            android:name=".service.ServiceRestartJobService"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <!-- Debug receiver for starting/stopping monitoring via ADB (debug only) -->
        <receiver
            android:name=".service.MonitoringDebugReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.skeddy.action.DEBUG_START_MONITORING" />
                <action android:name="com.skeddy.action.DEBUG_STOP_MONITORING" />
            </intent-filter>
        </receiver>

        <!-- Boot completed receiver for auto-starting monitoring after reboot -->
        <receiver
            android:name=".service.BootCompletedReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
